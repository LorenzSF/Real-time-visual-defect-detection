{
  "run": {
    "seed": 42,
    "output_dir": "data/runs",
    "run_name": "baseline"
  },
  "dataset": {
    "source_type": "zip",
    "path": "data/raw/sample.zip",
    "extract_dir": "data/raw/extracted",
    "image_glob": "**/*.png"
  },
  "preprocessing": {
    "resize": {
      "enabled": true,
      "width": 256,
      "height": 256
    },
    "normalize": {
      "enabled": true,
      "mode": "0_1"
    }
  },
  "corruption": {
    "enabled": false,
    "type": "gaussian_noise",
    "params": {
      "sigma": 10.0,
      "ksize": 5,
      "scale": 0.5
    }
  },
  "model": {
    "name": "dummy_distance",
    "threshold": 0.5
  },
  "evaluation": {
    "metrics": [
      "precision",
      "recall",
      "f1",
      "accuracy"
    ]
  }
}